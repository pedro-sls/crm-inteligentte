# Neon/PostgreSQL - use somente valores reais no arquivo .env local ou no provedor de deploy.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth
AUTH_SECRET="gere-um-segredo-com-pelo-menos-32-caracteres"
# Opcional: hosts/origens adicionais separados por virgula para preview, rede local ou deploy.
AUTH_ALLOWED_HOSTS="crm.suaempresa.com,preview-*.vercel.app"
AUTH_TRUSTED_ORIGINS="https://crm.suaempresa.com,https://preview-*.vercel.app"

# Integracoes
WEBHOOK_SIGNING_SECRET="gere-um-segredo-com-pelo-menos-32-caracteres"
API_KEY_PEPPER="gere-um-segredo-com-pelo-menos-32-caracteres"
