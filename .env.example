# Neon/PostgreSQL - use somente valores reais no arquivo .env local ou no provedor de deploy.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth
AUTH_SECRET="troque-por-um-segredo-forte"

# Integracoes
WEBHOOK_SIGNING_SECRET="troque-por-um-segredo-forte"
API_KEY_PEPPER="troque-por-um-segredo-forte"
